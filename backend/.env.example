DATABASE_URL=postgresql://postgres:postgres@localhost:5432/discovery_engine
# Separate database used only by the integration test suite (pnpm test). Never
# points at the same database as DATABASE_URL — tests truncate tables freely.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/discovery_engine_test
ANTHROPIC_API_KEY=sk-ant-your-key-here
VOYAGE_API_KEY=pa-your-key-here
# Optional. Defaults to 3 (Voyage's free-tier cap with no payment method on file).
# Once a payment method is on file, set this to the account's real limit (e.g. Tier 1
# is 2,000 RPM) — check https://docs.voyageai.com/docs/rate-limits for current tiers.
# VOYAGE_MAX_REQUESTS_PER_MINUTE=2000
PORT=4000
